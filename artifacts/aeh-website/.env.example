# ─────────────────────────────────────────────
#  AEH Website (Vite) — Environment Variables
#  Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# Required by Vite dev server
PORT=21165

# Base path for the app (use / for local dev)
BASE_PATH=/

# API base URL — leave empty to use Vite proxy (/api → localhost:8080)
# Only set this if NOT using the Vite proxy (e.g., deployed frontend)
# VITE_API_URL=http://localhost:8080/api
